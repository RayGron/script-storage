#!/usr/bin/env bash
set -euo pipefail

# Friendly command wrapper:
#   mlman train|infer|stop|status|check|apply-profile|model-*

if command -v ml-mode.sh >/dev/null 2>&1; then
  exec ml-mode.sh "$@"
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
exec "${SCRIPT_DIR}/ml-mode.sh" "$@"
